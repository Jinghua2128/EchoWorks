rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin(email) {
      return signedIn()
        && request.auth.token.email == "liuguangxuan1230@gmail.com"
        && email == request.auth.token.email;
    }

    function isDashboardAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/dashboardAdminEmails/$(request.auth.token.email));
    }

    function writesBootstrapAdminProfile(email) {
      return isBootstrapAdmin(email)
        && request.resource.data.email == request.auth.token.email;
    }

    function ownsUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function writesOwnScenarioResult(resultId) {
      return signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.scenarioId is string
        && resultId == request.auth.uid + "_" + request.resource.data.scenarioId;
    }

    match /users/{uid} {
      allow create, read, update: if ownsUser(uid) || isDashboardAdmin();
      allow delete: if isDashboardAdmin();

      match /scenarioProgress/{scenarioId} {
        allow read, write: if ownsUser(uid) || isDashboardAdmin();
      }
    }

    match /scenarioResults/{resultId} {
      allow create, update: if writesOwnScenarioResult(resultId) || isDashboardAdmin();
      allow read: if (signedIn() && resource.data.uid == request.auth.uid) || isDashboardAdmin();
      allow list: if isDashboardAdmin();
      allow delete: if (signedIn() && resource.data.uid == request.auth.uid) || isDashboardAdmin();
    }

    match /dashboardAdminEmails/{email} {
      allow get: if isDashboardAdmin() || (signedIn() && request.auth.token.email == email);
      allow list: if isDashboardAdmin();
      allow create: if isDashboardAdmin() || writesBootstrapAdminProfile(email);
      allow update, delete: if isDashboardAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
